PORT=8787
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=YOUR_DIFY_API_KEY
CORS_ORIGIN=*
MAX_FILE_MB=12
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
TOKEN_EXPIRES_IN=30d
DB_PATH=./data/store.json

# Account/password auth policy
PASSWORD_MIN_LEN=6
PASSWORD_MAX_LEN=72
PASSWORD_PBKDF2_ITERATIONS=120000

# Optional: legacy email-code login (can keep disabled)
EMAIL_PROVIDER=mock
