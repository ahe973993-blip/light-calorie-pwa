PORT=8787
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=YOUR_DIFY_API_KEY
CORS_ORIGIN=*
MAX_FILE_MB=12
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
TOKEN_EXPIRES_IN=30d
DB_PATH=./data/store.json

# Auth
# mock: local debug
# smtp: free production (QQ/163)
# resend: production with custom domain
EMAIL_PROVIDER=mock
EMAIL_CODE_TTL_SEC=300
EMAIL_COOLDOWN_SEC=60
EMAIL_DAILY_LIMIT=20
EMAIL_DEBUG_RETURN_CODE=false
EMAIL_SUBJECT=轻卡小记登录验证码

# SMTP (set when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Resend (set when EMAIL_PROVIDER=resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@your-domain.com
